WEB_PORT=8088

# Printer values come from the printer display / Bambu Studio device page.
BAMBU_HOST=192.0.2.10
BAMBU_SERIAL=YOUR_PRINTER_SERIAL
BAMBU_ACCESS_CODE=YOUR_LAN_ACCESS_CODE
BAMBU_MQTT_PORT=8883
BAMBU_FTPS_PORT=990

# Single-material STL defaults. AMS slots are discovered live from printer status.
DEFAULT_INFILL_DENSITY=15
DEFAULT_WALL_LOOPS=2
DEFAULT_PLATE_INDEX=1

# Slicer setup. Mount the executable or wrapper under ./slicer and point here.
SLICER_BIN=/slicer/BambuStudio.AppImage
SLICER_USE_XVFB=true
SLICER_PLATE_INDEX=0
SLICER_TIMEOUT_SECONDS=900
MACHINE_PROFILE=/config/machine.json
PROCESS_PROFILE=/config/process.json
FILAMENT_PROFILE_DIR=/config/filaments

# If no exact AMS filament-type profile exists, this generic profile is used.
FALLBACK_FILAMENT_PROFILE=/config/filaments/generic.json
